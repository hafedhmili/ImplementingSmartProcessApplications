    <NodeList>
      <TaskNode Identifier="node2" Task="task_0"/>
      <TaskNode Identifier="node_1" Task="general"/>
      <TaskNode Identifier="node_2" Task="shopperfitness"/>
      <TaskNode Identifier="node3" Task="task_3"/>
    </NodeList>
    <TransitionList>
      <Transition Identifier="link4" Source="node2" Target="node_1"/>
      <Transition Identifier="link5" Source="node_1" Target="node_2"/>
      <Transition Identifier="link6" Source="node_2" Target="node3"/>
    </TransitionList>
  </Body>
  <Resources>
