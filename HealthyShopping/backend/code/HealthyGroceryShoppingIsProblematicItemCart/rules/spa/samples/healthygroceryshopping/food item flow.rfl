  <rfModel>
<Ruleflow xmlns="http://schemas.ilog.com/Rules/7.0/Ruleflow">
  <Body>
    <TaskList>
      <StartTask Identifier="task_0"/>
      <RuleTask ExecutionMode="Fastpath" ExitCriteria="None" Identifier="general" Ordering="Default">
        <RuleList>
          <Package Name="spa.samples.healthygroceryshopping.productitemrules.general"/>
